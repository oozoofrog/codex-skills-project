{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_type",
    "schema_version",
    "target",
    "documents_found",
    "findings_count",
    "strengths_count",
    "findings",
    "strengths"
  ],
  "properties": {
    "report_type": {"const": "agent-context-verify"},
    "schema_version": {"type": "integer", "const": 1},
    "target": {"type": "string"},
    "documents_found": {"type": "integer", "minimum": 0},
    "findings_count": {"type": "integer", "minimum": 0},
    "strengths_count": {"type": "integer", "minimum": 0},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "where", "message"],
        "properties": {
          "severity": {"type": "string"},
          "where": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    },
    "strengths": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
